APP_NAME="Member Discounts"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# This project uses SQLite. `php artisan migrate --seed` creates and seeds
# database/database.sqlite for you.
DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=sync

BCRYPT_ROUNDS=12

# Mail is logged in this demo rather than sent.
MAIL_MAILER=log
